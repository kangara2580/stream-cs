# ==============================
# StreamCS 서버 환경변수 설정
# .env.example → .env 복사 후 값 입력
# ==============================

# 서버 포트 (Railway/Render 자동 지정 시 비워도 됨)
PORT=3001

# Supabase 연결
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY

# 트위치 봇 계정 (봇 전용 계정 추천)
TWITCH_BOT_USERNAME=your_bot_name
TWITCH_BOT_TOKEN=oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 유튜브 API (선택)
YOUTUBE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 보안 키 (오버레이 인증용, 아무 랜덤 문자열)
OVERLAY_SECRET=streamcs_secret_key_change_this
