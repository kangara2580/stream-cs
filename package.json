{
  "name": "stream-cs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/generate-supabase-config.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:fresh": "DEV_FRESH=1 node scripts/dev.mjs",
    "dev:kill": "sh -c 'lsof -ti :3000 | xargs kill -9 2>/dev/null || true'",
    "prebuild": "node scripts/generate-supabase-config.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "ws:install": "cd ws-server && npm install",
    "ws:dev": "cd ws-server && npm run dev",
    "ws:start": "cd ws-server && npm start"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/postcss": "^4.3.0",
    "next": "^15.3.3",
    "postcss": "^8.5.15",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "typescript": "^5.8.3"
  }
}
